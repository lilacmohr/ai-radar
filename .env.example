# ai-radar — secrets template
# Copy to .env and fill in your values. Never commit .env.

# GitHub Models API token (required if using github/ models)
# Obtain from: https://github.com/settings/tokens (classic token, no scopes needed)
# GH_MODELS_TOKEN is used by GitHub Actions. GITHUB_API_KEY is the name LiteLLM expects.
# Set both to the same token value.
GH_MODELS_TOKEN=your_github_models_token_here
GITHUB_API_KEY=your_github_models_token_here

# Gmail OAuth credentials (required only if sources.gmail.enabled = true)
# Obtain from: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Required OAuth scope: https://www.googleapis.com/auth/gmail.readonly
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# Anthropic API key (required only if fallback model is anthropic/)
ANTHROPIC_API_KEY=

# Langfuse observability (optional — omit to disable tracing silently)
# Obtain from: https://cloud.langfuse.com — Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com  # override for self-hosted instances

# Log level (optional, default: INFO)
# Set to WARNING in CI to suppress verbose per-stage output
# Never set to DEBUG in CI — may expose auth headers in litellm/google client debug output
LOG_LEVEL=INFO
