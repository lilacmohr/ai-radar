# ai-radar — secrets template
# Copy to .env and fill in your values. Never commit .env.

# GitHub Models API token (required)
# Obtain from: https://github.com/settings/tokens (classic token, no scopes needed)
# Used for: LLM inference via the GitHub Models OpenAI-compatible API endpoint
GH_MODELS_TOKEN=your_github_models_token_here

# Gmail OAuth credentials (required only if sources.gmail.enabled = true)
# Obtain from: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Required OAuth scope: https://www.googleapis.com/auth/gmail.readonly
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# Log level (optional, default: INFO)
# Set to WARNING in CI to suppress verbose per-stage output
# Never set to DEBUG in CI — may expose auth headers in openai/google client debug output
LOG_LEVEL=INFO
